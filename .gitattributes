# Standardize line endings
# Set default behavior to handle all files as text and force LF in the repo
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.js    text
*.jsx   text
*.ts    text
*.tsx   text
*.css   text
*.html  text
*.md    text
*.json  text

# Denote all files that are truly binary and should not be modified.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text
